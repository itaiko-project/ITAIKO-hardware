//Button assignments
#define LEFT_KAT_BTN 'D'
#define LEFT_DON_BTN 'F'
#define RIGHT_DON_BTN 'J'
#define RIGHT_KAT_BTN 'K'

//Button pins
#define BTN_A        2     //South
#define BTN_R        0     //R
#define BTN_X        1     //North
#define BTN_START    3     //Start
#define BTN_Y        8     //East
#define BTN_B        4     //West
#define BTN_HOME1    5     //Home
#define BTN_DOWN     9     //Down
#define BTN_RIGHT    10    //Right
#define BTN_SCREEN   11    //Share
#define BTN_UP       13    //Up
#define BTN_SELECT   14    //Select
#define BTN_LEFT     12    //Left
#define BTN_L        15    //L

//Keyboard key mappings
#define KEY_A        KEY_RETURN
#define KEY_R        'R'
#define KEY_X        'X'
#define KEY_START    KEY_ESC
#define KEY_Y        'Y'
#define KEY_B        'B'
#define KEY_HOME1    KEY_LEFT_GUI
#define KEY_DOWN     KEY_DOWN_ARROW
#define KEY_RIGHT    KEY_RIGHT_ARROW
#define KEY_SCREEN   'P'
#define KEY_UP       KEY_UP_ARROW
#define KEY_SELECT   'Q'
#define KEY_LEFT     KEY_LEFT_ARROW
#define KEY_L        'L'

