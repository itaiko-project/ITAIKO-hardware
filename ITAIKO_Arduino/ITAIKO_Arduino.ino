  BTN_A, BTN_R, BTN_X, BTN_START, BTN_Y, BTN_B, BTN_HOME1,
  BTN_DOWN, BTN_RIGHT, BTN_SCREEN, BTN_UP, BTN_SELECT, BTN_LEFT, BTN_L
};

